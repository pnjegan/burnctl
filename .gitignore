# Claudash — files intentionally kept out of source control

# ── Runtime data (regenerated from JSONL on every scan) ──
data/usage.db
data/usage.db-wal
data/usage.db-shm
data/*.csv

# ── Local tool variants ──
tools/mac-sync-local.py
tools/oauth_sync-local.py

# ── Python build artifacts ──
__pycache__/
*.pyc
*.pyo
*.pyd

# ── Environment / secrets ──
.env
.env.local
*.pem

# ── OS junk ──
.DS_Store
Thumbs.db
Desktop.ini

# ── Logs ──
*.log

# ── Editor state ──
.vscode/
.idea/
*.swp
*.swo

# ── Packaging sandbox (if someone ever ships a PyPI package) ──
claudash/
dist/
build/
*.egg-info/
FOUNDING_DOC.md
END_USER_REVIEW.md
REPORT.md
usage_export.csv

# ── Local agent / CDC tracking (per-machine only) ──
.claude/
.dev-cdc/
.npmrc
claudash.db

# ── Guardian pipeline local reports (not tracked) ──
research-reports/
audit-reports/
checklists/

# ── fix-rules output (project-specific data, never push) ──
generated-claude-rules.txt

# ── Session summaries + handoffs (operator-only, never push) ──
session-*.txt
session-*-summary.txt
session-*-handoff.md
session-*-handoff.txt
SESSION_*.md
SESSION_*.txt

# ── Operator notes + scratchpads (never push) ──
NOTES.md
NOTES.txt
*-notes.txt
notes/
scratch/
scratchpad/
SCRATCH.md
SCRATCH.txt

# ── Teaching / tutorial / lesson drafts (operator-only) ──
teaching-*.md
teaching-*.txt
tutorial-*.md
tutorial-*.txt
lesson-*.md
lesson-*.txt
learnings/

# ── Drafts (operator-only) ──
*-draft.md
*-draft.txt
draft-*.md
draft-*.txt
drafts/

# ── Briefings + handoffs (operator-only) ──
brief-*.md
brief-*.txt
briefing-*.md
briefing-*.txt
handoff-*.md
handoff-*.txt

# ── Local TODOs (operator-only; FIXES_TODO.md rule is separate) ──
TODO.txt
*-todo.txt
todos/

# ── Plan docs (operator-only) ──
plan-*.md
plan-*.txt
PLAN.md
PLAN.txt

# Internal docs — never push to GitHub (permanent rule)
BURNCTL_MASTER_DOC*.md
CLAUDE.md
MEMORY.md
INTERNALS.md
FIXES_TODO.md
FOUNDING_DOC*.md
docs/audits/
qa-reports/
research-reports/
audit-reports/
checklists/
.dev-cdc/
*-audit.txt
burnctl-complete-audit.txt

# Session backup files (auto-generated during edits)
*.bak-*
